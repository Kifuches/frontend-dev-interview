---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const homeUrl = base;
const materialsUrl = `${base}materials/`;
---

<header class="topbar">
  <div class="shell topbar-inner">
    <a class="brand" href={homeUrl} aria-label="На главную">
      <span class="brand-mark" aria-hidden="true">IC</span>
      <span>InterviewCatalog</span>
    </a>
    <nav class="nav" aria-label="Основная навигация">
      <a href={homeUrl}>Catalog</a>
      <a href={materialsUrl}>Resources</a>
      <a href="https://docs.astro.build/" rel="noreferrer" target="_blank">Astro Docs</a>
    </nav>
  </div>
</header>
